OPENAI_API_KEY="your-openai-api-key-here"
HF_TOKEN="your-huggingface-token-here"  # Optional, purely for feedback syncing

# GPU Backend (Vast.ai / RunPod) - Optional
# Set these when you have a GPU server running vLLM
VLLM_BASE_URL=""           # e.g. "http://203.0.113.50:8000/v1" (leave empty to disable GPU backend)
VLLM_API_KEY=""            # API key for your vLLM server (leave empty if not using auth)
VLLM_MODEL_NAME=""         # e.g. "Qwen/Qwen3.5-35B-A3B-GPTQ-Int4" (must match --model used in vLLM)
BGE_RERANKER_URL=""        # e.g. "http://203.0.113.50:8001/rerank" (leave empty to use FlashRank)
